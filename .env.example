# ─── LLM Configuration ───────────────────────────────────────────────
MISTRAL_API_KEY=your-mistral-api-key-here
LITELLM_LOG=INFO

# ─── Database ────────────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=cyberteam
POSTGRES_USER=cyberteam
POSTGRES_PASSWORD=changeme-postgres-password

# ─── Redis ───────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=changeme-redis-password

# ─── Qdrant (Vector DB) ─────────────────────────────────────────────
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_API_KEY=

# ─── Temporal ────────────────────────────────────────────────────────
TEMPORAL_HOST=temporal
TEMPORAL_PORT=7233
TEMPORAL_NAMESPACE=default

# ─── Keycloak (Auth) ────────────────────────────────────────────────
KEYCLOAK_HOST=keycloak
KEYCLOAK_PORT=8080
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=changeme-keycloak-admin
KEYCLOAK_REALM=cyberteam

# ─── OpenFGA (Authorization) ────────────────────────────────────────
OPENFGA_HOST=openfga
OPENFGA_PORT=8080
OPENFGA_API_URL=http://openfga:8080

# ─── OPA (Policy) ───────────────────────────────────────────────────
OPA_HOST=opa
OPA_PORT=8181
OPA_API_URL=http://opa:8181

# ─── Reserved: Infisical (not wired into runtime yet) ────────────────
INFISICAL_TOKEN=

# ─── ERPNext ────────────────────────────────────────────────────────
ERPNEXT_IMAGE=frappe/erpnext:v16.21.1
ERPNEXT_URL=http://erpnext-frontend:8080
ERPNEXT_SITE_NAME=erpnext.hyperailab.com
ERPNEXT_EDGE_DOMAIN=erpnext.hyperailab.com
ERPNEXT_PUBLISHED_PORT=18100
ERPNEXT_ADMIN_PASSWORD=changeme-erpnext-admin
ERPNEXT_MARIADB_ROOT_PASSWORD=changeme-erpnext-mariadb-root
ERPNEXT_DB_PASSWORD=changeme-erpnext-db-password
ERPNEXT_INTEGRATION_USER=cyberteam.integration@example.local
ERPNEXT_CADDY_BASIC_AUTH_USER=cyberteam
ERPNEXT_CADDY_BASIC_AUTH_PASSWORD=changeme-erpnext-caddy-basic-auth
ERPNEXT_API_KEY=
ERPNEXT_API_SECRET=
ERPNEXT_DRIFT_DETECTION_ENABLED=false
ERPNEXT_DRIFT_INITIAL_DELAY_SECONDS=300
ERPNEXT_DRIFT_INTERVAL_SECONDS=3600
ERPNEXT_DRIFT_STALE_AFTER_HOURS=24
ERPNEXT_DRIFT_APPLY_LOW_RISK=true
ERPNEXT_DRIFT_RUN_PLANNER=true
REQUIRED_COMMUNICATION_PROVIDERS=smtp,imap,erpnext
GITHUB_TOKEN=
GITHUB_REPOSITORY=
GITHUB_DEFAULT_WORKFLOW=ci.yml
GITHUB_DEFAULT_REF=main

# ─── Telephony / SMS ────────────────────────────────────────────────
COMMUNICATIONS_ALLOW_SIMULATION=true
COMMUNICATIONS_RETRY_ATTEMPTS=2
COMMUNICATIONS_RETRY_BACKOFF_SECONDS=0.25
COMMUNICATIONS_PROVIDER_TIMEOUT_SECONDS=10
COMMUNICATIONS_CIRCUIT_BREAKER_FAILURE_THRESHOLD=3
COMMUNICATIONS_CIRCUIT_BREAKER_COOLDOWN_SECONDS=60
RETENTION_MEMORY_DAYS=365
RETENTION_COMMUNICATION_LOG_DAYS=365
RETENTION_WORKFLOW_RUN_DAYS=180
RETENTION_APPROVAL_REQUEST_DAYS=730
RETENTION_AUDIT_EVENT_DAYS=2555
RETENTION_BATCH_SIZE=500
AUTONOMOUS_OPERATIONS_ENABLED=true
AUTONOMOUS_OPERATIONS_INITIAL_DELAY_SECONDS=60
AUTONOMOUS_OPERATIONS_INTERVAL_SECONDS=900
AUTONOMOUS_PLANNER_ENABLED=true
AUTONOMOUS_PLANNER_AUTO_EXECUTE_SAFE_TASKS=true
AUTONOMOUS_PLANNER_SCAN_LIMIT=50
OWNER_CONSOLE_URL=http://localhost:3000
OWNER_ATTENTION_NOTIFICATIONS_ENABLED=true
OWNER_ATTENTION_NOTIFICATION_INITIAL_DELAY_SECONDS=180
OWNER_ATTENTION_NOTIFICATION_INTERVAL_SECONDS=900
OWNER_ATTENTION_NOTIFICATION_LIMIT=100
OWNER_ATTENTION_NOTIFICATION_MIN_PRIORITY=medium
OWNER_ATTENTION_NOTIFICATION_COOLDOWN_HOURS=24
SUPERVISOR_REVIEW_ENABLED=true
SUPERVISOR_REVIEW_INITIAL_DELAY_SECONDS=60
SUPERVISOR_REVIEW_INTERVAL_SECONDS=900
SUPERVISOR_REVIEW_STALE_APPROVAL_HOURS=24
SUPERVISOR_REVIEW_FAILURE_LOOKBACK_HOURS=24
SUPERVISOR_REVIEW_FAILURE_THRESHOLD=3
MEMORY_STEWARD_ENABLED=true
MEMORY_STEWARD_INITIAL_DELAY_SECONDS=120
MEMORY_STEWARD_INTERVAL_SECONDS=1800
MEMORY_STEWARD_TRACE_LOOKBACK_HOURS=24
MEMORY_STEWARD_TRACE_LIMIT=200
MEMORY_STEWARD_EMPTY_RECALL_THRESHOLD=3
MEMORY_STEWARD_STALE_PROCEDURAL_DAYS=30
MEMORY_STEWARD_PLANNER_ENABLED=true
MEMORY_STEWARD_AUTO_APPLY_SAFE_ACTIONS=true
MEMORY_STEWARD_REQUEST_ACTION_APPROVALS=true
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_WHATSAPP_FROM_NUMBER=
ASTERISK_ARI_ENABLED=false
ASTERISK_ARI_USE_TLS=false
ASTERISK_ARI_APP=cyberteam
ASTERISK_ARI_ENDPOINT_TEMPLATE=PJSIP/{to_number}
ASTERISK_CALLER_ID=Cyber-Team
ASTERISK_HOST=asterisk
ASTERISK_PORT=8088
ASTERISK_ARI_USER=cyberteam
ASTERISK_ARI_PASSWORD=changeme-ari-password
JASMIN_HOST=jasmin
JASMIN_PORT=1401
JASMIN_USERNAME=
JASMIN_PASSWORD=
JASMIN_FROM_NUMBER=
JASMIN_USE_TLS=false

# ─── Messaging ──────────────────────────────────────────────────────
SLACK_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=

# ─── Email (SMTP) ───────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=false
SMTP_STARTTLS=true

# ─── Langfuse (Observability) ───────────────────────────────────────
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://langfuse:3000

# ─── Grafana ─────────────────────────────────────────────────────────
GRAFANA_ADMIN_PASSWORD=changeme-grafana-admin

# ─── App Settings ───────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO
APP_VERSION=0.1.0
BUILD_SHA=local
SECRET_KEY=changeme-app-secret-key
CORS_ALLOWED_ORIGINS=*
OWNER_EMAIL=owner@example.com
OWNER_PASSWORD=changeme-owner-password
# Production requires OWNER_PASSWORD_HASH. Generate with:
#   cd backend && python -m cyber_team.cli hash-password
OWNER_PASSWORD_HASH=
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
WEBSOCKET_TICKET_EXPIRE_SECONDS=30
RATE_LIMIT_LOGIN_PER_MINUTE=10
RATE_LIMIT_REFRESH_PER_MINUTE=30
RATE_LIMIT_WEBSOCKET_TICKET_PER_MINUTE=30
RATE_LIMIT_CHAT_PER_MINUTE=60
RATE_LIMIT_TOOL_EXECUTE_PER_MINUTE=30
RATE_LIMIT_APPROVAL_PER_MINUTE=30
AUTONOMY_SIDE_EFFECT_MODE=manual_only
REQUIRE_LIVE_TOOL_EXECUTORS=false
