# ─── LLM Configuration ───────────────────────────────────────────────
MISTRAL_API_KEY=your-mistral-api-key-here
LITELLM_LOG=INFO

# ─── Database ────────────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=cyberteam
POSTGRES_USER=cyberteam
POSTGRES_PASSWORD=changeme-postgres-password

# ─── Redis ───────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=changeme-redis-password

# ─── Qdrant (Vector DB) ─────────────────────────────────────────────
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_API_KEY=

# ─── Temporal ────────────────────────────────────────────────────────
TEMPORAL_HOST=temporal
TEMPORAL_PORT=7233
TEMPORAL_NAMESPACE=default

# ─── Keycloak (Auth) ────────────────────────────────────────────────
KEYCLOAK_HOST=keycloak
KEYCLOAK_PORT=8080
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=changeme-keycloak-admin
KEYCLOAK_REALM=cyberteam

# ─── OpenFGA (Authorization) ────────────────────────────────────────
OPENFGA_HOST=openfga
OPENFGA_PORT=8080
OPENFGA_API_URL=http://openfga:8080

# ─── OPA (Policy) ───────────────────────────────────────────────────
OPA_HOST=opa
OPA_PORT=8181
OPA_API_URL=http://opa:8181

# ─── Reserved: Infisical (not wired into runtime yet) ────────────────
INFISICAL_TOKEN=

# ─── ERPNext ────────────────────────────────────────────────────────
ERPNEXT_URL=http://erpnext:8000
ERPNEXT_API_KEY=
ERPNEXT_API_SECRET=

# ─── Telephony / SMS ────────────────────────────────────────────────
COMMUNICATIONS_ALLOW_SIMULATION=true
COMMUNICATIONS_RETRY_ATTEMPTS=2
COMMUNICATIONS_RETRY_BACKOFF_SECONDS=0.25
COMMUNICATIONS_PROVIDER_TIMEOUT_SECONDS=10
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_WHATSAPP_FROM_NUMBER=
ASTERISK_HOST=asterisk
ASTERISK_PORT=8088
ASTERISK_ARI_USER=cyberteam
ASTERISK_ARI_PASSWORD=changeme-ari-password
JASMIN_HOST=jasmin
JASMIN_PORT=1401
JASMIN_USERNAME=
JASMIN_PASSWORD=
JASMIN_FROM_NUMBER=
JASMIN_USE_TLS=false

# ─── Messaging ──────────────────────────────────────────────────────
SLACK_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=

# ─── Email (SMTP) ───────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=false
SMTP_STARTTLS=true

# ─── Langfuse (Observability) ───────────────────────────────────────
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://langfuse:3000

# ─── Grafana ─────────────────────────────────────────────────────────
GRAFANA_ADMIN_PASSWORD=changeme-grafana-admin

# ─── App Settings ───────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO
SECRET_KEY=changeme-app-secret-key
CORS_ALLOWED_ORIGINS=*
OWNER_EMAIL=owner@example.com
OWNER_PASSWORD=changeme-owner-password
# Production requires OWNER_PASSWORD_HASH. Generate with:
#   cd backend && python -m cyber_team.cli hash-password
OWNER_PASSWORD_HASH=
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
WEBSOCKET_TICKET_EXPIRE_SECONDS=30
RATE_LIMIT_LOGIN_PER_MINUTE=10
RATE_LIMIT_REFRESH_PER_MINUTE=30
RATE_LIMIT_WEBSOCKET_TICKET_PER_MINUTE=30
RATE_LIMIT_CHAT_PER_MINUTE=60
RATE_LIMIT_TOOL_EXECUTE_PER_MINUTE=30
RATE_LIMIT_APPROVAL_PER_MINUTE=30
