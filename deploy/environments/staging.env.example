# Copy to deploy/environments/staging.env and replace placeholders before use.

# Compose isolation
COMPOSE_PROJECT_NAME=cyberteam-staging
CYBERTEAM_ENV_FILE=deploy/environments/staging.env
CYBERTEAM_CONTAINER_PREFIX=cyberteam-staging
CYBERTEAM_NETWORK_NAME=cyberteam-staging-network
API_PUBLISHED_PORT=18000
UI_PUBLISHED_PORT=13001
POSTGRES_PUBLISHED_PORT=15432
REDIS_PUBLISHED_PORT=16379
QDRANT_HTTP_PUBLISHED_PORT=16333
QDRANT_GRPC_PUBLISHED_PORT=16334
TEMPORAL_PUBLISHED_PORT=17233
OPA_PUBLISHED_PORT=18181
PROMETHEUS_PUBLISHED_PORT=19099
GRAFANA_PUBLISHED_PORT=13500
API_BASE=http://localhost:18000
UI_BASE=http://localhost:13001
NEXT_PUBLIC_API_URL=http://localhost:18000
NEXT_PUBLIC_WS_URL=ws://localhost:18000
APP_VERSION=0.1.0
BUILD_SHA=local

# Runtime security
ENVIRONMENT=staging
LOG_LEVEL=INFO
SECRET_KEY=replace-with-staging-secret-key
CORS_ALLOWED_ORIGINS=http://localhost:13001
OWNER_EMAIL=owner@example.com
OWNER_PASSWORD=replace-with-staging-owner-password
OWNER_PASSWORD_HASH=
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
WEBSOCKET_TICKET_EXPIRE_SECONDS=30

# Datastores
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=cyberteam
POSTGRES_USER=cyberteam
POSTGRES_PASSWORD=replace-with-staging-postgres-password
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=replace-with-staging-redis-password
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_API_KEY=
TEMPORAL_HOST=temporal
TEMPORAL_PORT=7233
TEMPORAL_NAMESPACE=default

# Policy and integrations
OPA_API_URL=http://opa:8181
OPENFGA_API_URL=http://openfga:8080
ERPNEXT_IMAGE=frappe/erpnext:v16.21.1
ERPNEXT_URL=http://erpnext-frontend:8080
ERPNEXT_SITE_NAME=erpnext.hyperailab.com
ERPNEXT_EDGE_DOMAIN=erpnext.hyperailab.com
ERPNEXT_PUBLISHED_PORT=18100
ERPNEXT_ADMIN_PASSWORD=replace-with-staging-erpnext-admin-password
ERPNEXT_MARIADB_ROOT_PASSWORD=replace-with-staging-erpnext-mariadb-root-password
ERPNEXT_DB_PASSWORD=replace-with-staging-erpnext-db-password
ERPNEXT_INTEGRATION_USER=cyberteam.integration@example.local
ERPNEXT_CADDY_BASIC_AUTH_USER=cyberteam
ERPNEXT_CADDY_BASIC_AUTH_PASSWORD=replace-with-staging-erpnext-caddy-basic-auth-password
ERPNEXT_API_KEY=
ERPNEXT_API_SECRET=
ERPNEXT_DRIFT_DETECTION_ENABLED=true
ERPNEXT_DRIFT_INITIAL_DELAY_SECONDS=300
ERPNEXT_DRIFT_INTERVAL_SECONDS=3600
ERPNEXT_DRIFT_STALE_AFTER_HOURS=24
ERPNEXT_DRIFT_APPLY_LOW_RISK=true
ERPNEXT_DRIFT_RUN_PLANNER=true
REQUIRED_COMMUNICATION_PROVIDERS=smtp,imap,erpnext
GITHUB_TOKEN=
GITHUB_REPOSITORY=Hyper-AI-Lab/cyber-team
GITHUB_DEFAULT_WORKFLOW=ci.yml
GITHUB_DEFAULT_REF=main
MISTRAL_API_KEY=
LITELLM_LOG=INFO

# Staging proof mode requires live configured providers from REQUIRED_COMMUNICATION_PROVIDERS.
COMMUNICATIONS_ALLOW_SIMULATION=false
COMMUNICATIONS_RETRY_ATTEMPTS=2
COMMUNICATIONS_RETRY_BACKOFF_SECONDS=0.25
COMMUNICATIONS_PROVIDER_TIMEOUT_SECONDS=10
COMMUNICATIONS_CIRCUIT_BREAKER_FAILURE_THRESHOLD=3
COMMUNICATIONS_CIRCUIT_BREAKER_COOLDOWN_SECONDS=60
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=false
SMTP_STARTTLS=true
INBOUND_EMAIL_ENABLED=false
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USERNAME=
IMAP_PASSWORD=
IMAP_USE_SSL=true
IMAP_MAILBOX=INBOX
INBOUND_EMAIL_ADDRESS=
INBOUND_EMAIL_POLL_INTERVAL_SECONDS=60
INBOUND_EMAIL_MAX_MESSAGES_PER_POLL=20
INBOUND_EMAIL_MARK_SEEN=false

# Retention
RETENTION_MEMORY_DAYS=365
RETENTION_COMMUNICATION_LOG_DAYS=365
RETENTION_WORKFLOW_RUN_DAYS=180
RETENTION_APPROVAL_REQUEST_DAYS=730
RETENTION_AUDIT_EVENT_DAYS=2555
RETENTION_BATCH_SIZE=500

# Autonomous operations loop
AUTONOMOUS_OPERATIONS_ENABLED=true
AUTONOMY_SIDE_EFFECT_MODE=manual_only
REQUIRE_LIVE_TOOL_EXECUTORS=true
AUTONOMOUS_OPERATIONS_INITIAL_DELAY_SECONDS=60
AUTONOMOUS_OPERATIONS_INTERVAL_SECONDS=900
AUTONOMOUS_PLANNER_ENABLED=true
AUTONOMOUS_PLANNER_AUTO_EXECUTE_SAFE_TASKS=true
AUTONOMOUS_PLANNER_SCAN_LIMIT=50

# Supervisor review loop
SUPERVISOR_REVIEW_ENABLED=true
SUPERVISOR_REVIEW_INITIAL_DELAY_SECONDS=60
SUPERVISOR_REVIEW_INTERVAL_SECONDS=900
SUPERVISOR_REVIEW_STALE_APPROVAL_HOURS=24
SUPERVISOR_REVIEW_FAILURE_LOOKBACK_HOURS=24
SUPERVISOR_REVIEW_FAILURE_THRESHOLD=3

# Memory steward loop
MEMORY_STEWARD_ENABLED=true
MEMORY_STEWARD_INITIAL_DELAY_SECONDS=120
MEMORY_STEWARD_INTERVAL_SECONDS=1800
MEMORY_STEWARD_TRACE_LOOKBACK_HOURS=24
MEMORY_STEWARD_TRACE_LIMIT=200
MEMORY_STEWARD_EMPTY_RECALL_THRESHOLD=3
MEMORY_STEWARD_STALE_PROCEDURAL_DAYS=30
MEMORY_STEWARD_PLANNER_ENABLED=true
MEMORY_STEWARD_AUTO_APPLY_SAFE_ACTIONS=true
MEMORY_STEWARD_REQUEST_ACTION_APPROVALS=true
