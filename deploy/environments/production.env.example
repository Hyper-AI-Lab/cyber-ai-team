# Copy to deploy/environments/production.env on the production host.
# Do not commit the real production.env file.

# Compose isolation
COMPOSE_PROJECT_NAME=cyberteam-production
CYBERTEAM_ENV_FILE=deploy/environments/production.env
CYBERTEAM_CONTAINER_PREFIX=cyberteam-production
CYBERTEAM_NETWORK_NAME=cyberteam-production-network
API_PUBLISHED_PORT=8000
UI_PUBLISHED_PORT=3001
POSTGRES_PUBLISHED_PORT=5432
REDIS_PUBLISHED_PORT=6379
QDRANT_HTTP_PUBLISHED_PORT=6333
QDRANT_GRPC_PUBLISHED_PORT=6334
TEMPORAL_PUBLISHED_PORT=7233
OPA_PUBLISHED_PORT=8181
PROMETHEUS_PUBLISHED_PORT=9099
GRAFANA_PUBLISHED_PORT=3500
API_BASE=https://api.example.com
UI_BASE=https://console.example.com
NEXT_PUBLIC_API_URL=https://api.example.com
NEXT_PUBLIC_WS_URL=wss://api.example.com

# Runtime security
ENVIRONMENT=production
LOG_LEVEL=INFO
SECRET_KEY=replace-with-production-secret-key
CORS_ALLOWED_ORIGINS=https://console.example.com
OWNER_EMAIL=owner@example.com
OWNER_PASSWORD_HASH=replace-with-bcrypt-hash-from-cyber-team-cli
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
WEBSOCKET_TICKET_EXPIRE_SECONDS=30

# Datastores
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=cyberteam
POSTGRES_USER=cyberteam
POSTGRES_PASSWORD=replace-with-production-postgres-password
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=replace-with-production-redis-password
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_API_KEY=
TEMPORAL_HOST=temporal
TEMPORAL_PORT=7233
TEMPORAL_NAMESPACE=default

# Policy and integrations
OPA_API_URL=http://opa:8181
OPENFGA_API_URL=http://openfga:8080
ERPNEXT_URL=http://erpnext:8000
MISTRAL_API_KEY=
LITELLM_LOG=INFO

# Production startup rejects simulated communications.
COMMUNICATIONS_ALLOW_SIMULATION=false
COMMUNICATIONS_RETRY_ATTEMPTS=2
COMMUNICATIONS_RETRY_BACKOFF_SECONDS=0.25
COMMUNICATIONS_PROVIDER_TIMEOUT_SECONDS=10
COMMUNICATIONS_CIRCUIT_BREAKER_FAILURE_THRESHOLD=3
COMMUNICATIONS_CIRCUIT_BREAKER_COOLDOWN_SECONDS=60
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=false
SMTP_STARTTLS=true
SLACK_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_WHATSAPP_FROM_NUMBER=

# Retention
RETENTION_MEMORY_DAYS=365
RETENTION_COMMUNICATION_LOG_DAYS=365
RETENTION_WORKFLOW_RUN_DAYS=180
RETENTION_APPROVAL_REQUEST_DAYS=730
RETENTION_AUDIT_EVENT_DAYS=2555
RETENTION_BATCH_SIZE=500
